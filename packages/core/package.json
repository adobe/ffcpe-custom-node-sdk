{
  "name": "@adobe/ffcpe-custom-node-core",
  "version": "0.1.0-alpha.0",
  "description": "WinterTC-aligned SDK for FFCPE (Firefly Creative Production for Enterprise) custom actions — Workflow Builder HTTP contract, JobStore, JobOrchestrator, runWorkerJob, IMS inbound auth, submit/status handlers.",
  "keywords": [
    "adobe",
    "ffcpe",
    "firefly",
    "creative-production",
    "enterprise",
    "custom-action",
    "wintertc"
  ],
  "license": "Apache-2.0",
  "author": "Adobe Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adobe/ffcpe-custom-node-sdk.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/adobe/ffcpe-custom-node-sdk/issues"
  },
  "homepage": "https://github.com/adobe/ffcpe-custom-node-sdk/tree/main/packages/core#readme",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "oxlint src test",
    "lint:fix": "oxlint src test --fix",
    "format": "oxfmt --write src test",
    "format:check": "oxfmt --check src test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@adobe/aio-lib-ims": "^7.0.2"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  }
}
