{
    "name": "@adobe/ffcpe-custom-node-app-builder",
    "version": "1.0.0",
    "description": "App Builder (OpenWhisk) integration for @adobe/ffcpe-custom-node-core — FFCPE custom actions, Hono, hono-openwhisk-adapter, IMS auth, aio-lib-state, async invoke.",
    "keywords": [
        "adobe",
        "app-builder",
        "openwhisk",
        "ffcpe",
        "firefly",
        "creative-production",
        "hono"
    ],
    "license": "Apache-2.0",
    "author": "Adobe Inc.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/adobe/ffcpe-custom-node-sdk.git",
        "directory": "packages/app-builder"
    },
    "bugs": {
        "url": "https://github.com/adobe/ffcpe-custom-node-sdk/issues"
    },
    "homepage": "https://github.com/adobe/ffcpe-custom-node-sdk/tree/main/packages/app-builder#readme",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "vite build",
        "lint": "oxlint src test",
        "lint:fix": "oxlint src test --fix",
        "format": "oxfmt --write src test",
        "format:check": "oxfmt --check src test",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "prepublishOnly": "pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build"
    },
    "engines": {
        "node": ">=22"
    },
    "peerDependencies": {
        "@adobe/aio-lib-core-logging": "^3.0.0",
        "@adobe/aio-lib-ims": "^7.0.0",
        "@adobe/aio-lib-state": "^5.0.0",
        "hono": "^4.0.0",
        "hono-openwhisk-adapter": "^2.0.0",
        "openwhisk": "^3.0.0"
    },
    "dependencies": {
        "@adobe/ffcpe-custom-node-core": "1.0.0"
    },
    "devDependencies": {
        "@adobe/aio-lib-core-logging": "^3.0.2",
        "@adobe/aio-lib-ims": "^8.1.2",
        "@adobe/aio-lib-state": "^5.3.1",
        "@types/node": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "hono": "^4.12.23",
        "hono-openwhisk-adapter": "^2.1.1",
        "openwhisk": "^3.21.9",
        "oxfmt": "catalog:",
        "oxlint": "catalog:",
        "oxlint-tsgolint": "catalog:",
        "typescript": "catalog:",
        "vite": "catalog:",
        "vite-plugin-dts": "catalog:",
        "vitest": "catalog:"
    },
    "publishConfig": {
        "access": "public"
    }
}
