{
  "name": "ffcpe-custom-node-sdk-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo watch build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "typecheck": "turbo run typecheck",
    "release": "multi-semantic-release --ignore-private-packages",
    "prepublishOnly": "pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "packages/*/test/**/*.ts": [
      "oxfmt --write",
      "oxlint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "multi-semantic-release": "3.1.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.9.15"
  }
}
